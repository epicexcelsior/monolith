{
  "name": "monolith",
  "private": true,
  "packageManager": "pnpm@10.13.1",
  "scripts": {
    "mobile": "pnpm --filter @monolith/mobile start",
    "mobile:android": "pnpm --filter @monolith/mobile android",
    "server": "pnpm --filter @monolith/server dev",
    "build:mobile": "pnpm --filter @monolith/mobile build",
    "lint": "pnpm -r lint",
    "typecheck": "pnpm -r typecheck",
    "clean": "pnpm -r exec rm -rf node_modules && rm -rf node_modules",
    "anchor:build": "anchor build",
    "anchor:test": "anchor test",
    "anchor:deploy": "anchor deploy --provider.cluster devnet",
    "android": "expo run:android",
    "ios": "expo run:ios"
  },
  "engines": {
    "node": ">=22.0.0"
  },
  "dependencies": {
    "expo": "^54.0.33",
    "react": "19.1.0",
    "react-native": "0.81.5"
  },
  "devDependencies": {
    "@coral-xyz/anchor": "^0.31.1",
    "@solana/web3.js": "^1.98.4",
    "@types/chai": "^5.2.3",
    "@types/mocha": "^10.0.10",
    "chai": "^6.2.2",
    "mocha": "^11.7.5",
    "sharp": "^0.34.5",
    "ts-mocha": "^11.1.0",
    "typescript": "~5.9.3"
  },
  "version": "1.0.0"
}
