# EAS Build ignore — prevents upload of non-essential files
# EAS does NOT use .gitignore, so we need this separately

# AI agent configs (contain symlinks that break EAS tarball on Windows)
.agents/
.agent/
.claude/
.gemini/

# Locally-generated native dirs — EAS must run expo prebuild itself
# so Gradle paths match the Linux build server, not our Windows machine
apps/mobile/android/
apps/mobile/ios/

# IDE
.vscode/
.idea/

# Git
.git/

# Anchor (not needed for mobile build)
programs/
.anchor/

# Server (not needed for mobile build)
apps/server/

# Video content engine (not needed for mobile build)
apps/video/

# Dependencies — EAS installs these on the build server
node_modules/

# OS files
.DS_Store
Thumbs.db

# Logs
*.log
