# =======================
# Monolith Game Server - Environment Configuration
# =======================
# Copy this to .env and fill in your values
# (.env is gitignored)

# Supabase (required for persistence — without these, server runs in-memory only)
SUPABASE_URL=https://your-project.supabase.co
SUPABASE_SERVICE_KEY=your-service-role-key-here

# Server port (optional, defaults to 2567)
# PORT=2567
