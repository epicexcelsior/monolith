# Local development environment variables
# Copy this to `.env.local` and update with your values
# (.env.local is gitignored)

# For LAN testing (same WiFi)
EXPO_PUBLIC_GAME_SERVER_URL=ws://192.168.1.84:2567

# For ngrok testing (update after each ngrok restart)
# EXPO_PUBLIC_GAME_SERVER_URL=ws://0.tcp.us-cal-1.ngrok.io:16355

# For production server (Railway)
# EXPO_PUBLIC_GAME_SERVER_URL=wss://monolith-server-production.up.railway.app

# Supabase (same for local + prod — single hosted project)
EXPO_PUBLIC_SUPABASE_URL=https://your-project.supabase.co
EXPO_PUBLIC_SUPABASE_KEY=your-anon-publishable-key
