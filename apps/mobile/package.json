{
  "name": "@monolith/mobile",
  "version": "1.0.0",
  "main": "./index.js",
  "scripts": {
    "start": "expo start",
    "dev": "expo start --dev-client --localhost",
    "android": "expo run:android",
    "android:build": "expo prebuild -p android",
    "build:preview": "eas build --profile preview --platform android",
    "build:dev": "eas build --profile development --platform android",
    "lint": "expo lint",
    "typecheck": "tsc --noEmit",
    "test": "jest",
    "ios": "expo run:ios"
  },
  "dependencies": {
    "@coral-xyz/anchor": "^0.31.1",
    "@expo-google-fonts/inter": "^0.4.2",
    "@expo-google-fonts/jetbrains-mono": "^0.4.1",
    "@expo-google-fonts/outfit": "^0.4.3",
    "@react-three/drei": "^9.122.0",
    "@react-three/fiber": "^9.1.0",
    "@solana-mobile/mobile-wallet-adapter-protocol": "^2.2.5",
    "@solana-mobile/mobile-wallet-adapter-protocol-web3js": "^2.2.5",
    "@solana/spl-token": "^0.4.13",
    "@solana/web3.js": "^1.98.4",
    "@supabase/supabase-js": "^2.49.0",
    "babel-plugin-module-resolver": "^5.0.2",
    "buffer": "^6.0.3",
    "colyseus.js": "^0.15.0",
    "expo": "~54.0.33",
    "expo-audio": "^1.1.1",
    "expo-blur": "^15.0.8",
    "expo-build-properties": "~1.0.9",
    "expo-constants": "~18.0.9",
    "expo-crypto": "~15.0.7",
    "expo-dev-client": "~6.0.20",
    "expo-file-system": "^19.0.21",
    "expo-font": "~14.0.10",
    "expo-gl": "~16.0.10",
    "expo-haptics": "~15.0.7",
    "expo-linking": "~8.0.8",
    "expo-router": "~6.0.10",
    "expo-secure-store": "~15.0.7",
    "expo-sharing": "^14.0.8",
    "expo-splash-screen": "~31.0.10",
    "expo-status-bar": "~3.0.9",
    "expo-system-ui": "~6.0.7",
    "expo-updates": "^29.0.16",
    "expo-web-browser": "~15.0.9",
    "react": "19.1.0",
    "react-dom": "19.1.0",
    "react-native": "0.81.5",
    "react-native-gesture-handler": "~2.28.0",
    "react-native-get-random-values": "~1.11.0",
    "react-native-reanimated": "~4.1.2",
    "react-native-safe-area-context": "~5.6.0",
    "react-native-screens": "~4.16.0",
    "react-native-view-shot": "^4.0.3",
    "readable-stream": "^4.7.0",
    "three": "~0.170.0",
    "wawa-vfx": "^1.2.10",
    "wawa-vfx-vanilla": "^1.2.10",
    "zustand": "^5.0.0"
  },
  "devDependencies": {
    "@babel/core": "^7.28.3",
    "@expo/ngrok": "^4.1.3",
    "@types/react": "~19.1.0",
    "@types/three": "~0.170.0",
    "@typescript-eslint/eslint-plugin": "^8.55.0",
    "@typescript-eslint/parser": "^8.55.0",
    "eslint": "^10.0.0",
    "eslint-config-expo": "^10.0.0",
    "jest": "^30.2.0",
    "jest-expo": "^53.0.14",
    "typescript": "~5.9.2"
  },
  "expo": {
    "doctor": {
      "reactNativeDirectoryCheck": {
        "listUnknownPackages": false
      }
    }
  },
  "jest": {
    "transform": {
      "^.+\\.(ts|tsx|js|jsx)$": "babel-jest"
    },
    "transformIgnorePatterns": [
      "node_modules/(?!((jest-)?react-native|@react-native(-community)?)|expo(nent)?|@expo(nent)?/.*|@expo-google-fonts/.*|@solana/web3.js|@solana/spl-token|@solana-mobile/.*|@coral-xyz/.*|@react-three/.*|three|zustand|wonka|@noble/.*|buffer|readable-stream|colyseus\\.js|@colyseus/.*)"
    ],
    "moduleNameMapper": {
      "^@/(.*)$": "<rootDir>/$1",
      "^@monolith/common$": "<rootDir>/../../packages/common/src"
    }
  },
  "private": true
}
